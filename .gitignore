# Runtime state (not committed)
# Match both .scrum/ directory (main repo) and .scrum symlink (PBI worktrees).
.scrum
.scrum/

# Git worktrees (project-local)
.worktrees/

# Claude Code local settings (user-specific)
.claude/settings.local.json
.claude/recovery/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
dist/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary
*.tmp
*.log

# Internal planning / design scratch (kept on disk, NOT published). These
# dev-only working docs can accumulate operational detail (Team IDs, hostnames,
# ad-hoc runbooks); ignoring the tree prevents accidentally committing that to
# the public repo. Canonical guidance/state lives in memory + deployed docs.
docs/superpowers/

# Source screen recordings + the demo video (hosted on GitHub, embedded in the
# README by URL — not committed). Deliverables are the derived .png in images/.
# These files are large (tens–hundreds of MB) and must not be committed.
*.mov
*.mp4
*.mp3

# Local Apple signing credentials + build outputs. These are secrets (private
# keys / notary API keys) or large derived artifacts and must NEVER be
# committed. The tmp/ dir is a scratch area for local signing runs.
tmp/
*.p12
*.p8
*.cer
*.certSigningRequest
*.dmg
