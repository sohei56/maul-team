{
  "test_runner": {
    "command": "pytest",
    "args": ["--tb=short", "-q"],
    "results_format": "junit",
    "results_path_template": ".scrum/pbi/{pbi_id}/metrics/test-results-r{round}.xml"
  },
  "coverage_tool": {
    "command": "coverage",
    "run_args": ["run", "--branch", "--source=src", "-m", "pytest"],
    "report_args": ["json", "-o"],
    "report_path_template": ".scrum/pbi/{pbi_id}/metrics/coverage-r{round}.json",
    "supports_branch": true
  },
  "pragma_pattern": "pragma: no cover",
  "path_guard": {
    "impl_globs": ["src/**", "lib/**"],
    "test_globs": ["tests/**", "**/*_test.py"]
  },
  "po_mode": "human",
  "po": {
    "max_clarification_rounds": 2,
    "max_integration_cycles": 3
  },
  "autonomous": {
    "max_iterations": 50,
    "max_wall_clock_hours": 8,
    "max_sprints": 8,
    "max_consecutive_failures": 3,
    "stop_block_budget_per_phase": 8,
    "permission_mode": "dontAsk",
    "notify_command": null,
    "fallback_model": null
  }
}
