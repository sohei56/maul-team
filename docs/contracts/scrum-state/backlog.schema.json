{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Product backlog",
  "type": "object",
  "required": ["items"],
  "additionalProperties": true,
  "properties": {
    "product_goal": {"type": ["string", "null"]},
    "next_pbi_id": {"type": "integer", "minimum": 1},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "pattern": "^pbi-[0-9]+$"},
          "title": {"type": "string", "minLength": 1},
          "description": {"type": ["string", "null"]},
          "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
          "catalog_targets": {
            "type": "array",
            "items": {"type": "string"},
            "uniqueItems": true
          },
          "status": {"enum": ["draft", "refined", "in_progress", "review", "done", "blocked"]},
          "priority": {"type": ["integer", "null"], "minimum": 0},
          "sprint_id": {"type": ["string", "null"], "pattern": "^sprint-[0-9]+$"},
          "implementer_id": {"type": ["string", "null"], "pattern": "^dev-[0-9]+-s[0-9]+$"},
          "reviewer_id": {"type": ["string", "null"], "pattern": "^dev-[0-9]+-s[0-9]+$"},
          "design_doc_paths": {"type": "array", "items": {"type": "string"}},
          "review_doc_path": {"type": ["string", "null"]},
          "depends_on_pbi_ids": {"type": "array", "items": {"type": "string", "pattern": "^pbi-[0-9]+$"}},
          "ux_change": {"type": "boolean"},
          "parent_pbi_id": {"type": ["string", "null"], "pattern": "^pbi-[0-9]+$"},
          "size": {"enum": ["XS", "S", "M", "L", "XL"]},
          "created_at": {"type": "string", "format": "date-time"},
          "updated_at": {"type": "string", "format": "date-time"},
          "merged_sha": {"type": "string", "pattern": "^[0-9a-f]{7,40}$"},
          "merged_at": {"type": "string", "format": "date-time"},
          "pipeline_summary": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "rounds_design": {"type": "integer", "minimum": 0},
              "rounds_impl": {"type": "integer", "minimum": 0},
              "final_coverage_c0": {"type": "number"},
              "final_coverage_c1": {"type": ["number", "null"]},
              "outcome": {"enum": ["complete", "escalated"]},
              "escalation_reason": {"type": ["string", "null"]}
            }
          }
        }
      }
    }
  }
}
