{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PBI pipeline internal state",
  "description": "Naming convention: merge_failure.kind uses bare values (conflict, artifact_missing, regression) while escalation_reason carries the merge_* prefix (merge_conflict, merge_artifact_missing, merge_regression) so it never collides with non-merge reasons such as stagnation or divergence.",
  "type": "object",
  "required": ["pbi_id", "started_at", "updated_at"],
  "additionalProperties": false,
  "properties": {
    "pbi_id": {"type": "string", "pattern": "^pbi-[0-9]+$"},
    "design_round": {"type": "integer", "minimum": 0},
    "impl_round": {"type": "integer", "minimum": 0},
    "design_status": {"enum": ["pending", "in_review", "fail", "pass"]},
    "impl_status": {"enum": ["pending", "in_review", "fail", "pass"]},
    "ut_status": {"enum": ["pending", "in_review", "fail", "pass"]},
    "coverage_status": {"enum": ["pending", "fail", "pass"]},
    "escalation_reason": {
      "type": ["string", "null"],
      "enum": [
        null,
        "stagnation",
        "divergence",
        "max_rounds",
        "budget_exhausted",
        "requirements_unclear",
        "coverage_tool_error",
        "coverage_tool_unavailable",
        "catalog_lock_timeout",
        "reviewer_unavailable",
        "stale_review_snapshot",
        "merge_conflict",
        "merge_artifact_missing",
        "merge_regression"
      ]
    },
    "branch": {"type": "string", "pattern": "^pbi/pbi-[0-9]+$"},
    "worktree": {"type": "string", "pattern": "^\\.scrum/worktrees/pbi-[0-9]+$"},
    "base_sha": {"type": "string", "pattern": "^[0-9a-f]{7,40}$"},
    "head_sha": {"type": "string", "pattern": "^[0-9a-f]{7,40}$"},
    "paths_touched": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "ready_at": {"type": "string", "format": "date-time"},
    "merged_sha": {"type": "string", "pattern": "^[0-9a-f]{7,40}$"},
    "merged_at": {"type": "string", "format": "date-time"},
    "merge_failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "pre_head_at_failure"],
      "properties": {
        "kind": {"enum": ["conflict", "artifact_missing", "regression"]},
        "paths": {"type": "array", "items": {"type": "string"}},
        "pre_head_at_failure": {"type": "string", "pattern": "^[0-9a-f]{7,40}$"}
      }
    },
    "merge_failure_count": {"type": "integer", "minimum": 0},
    "started_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  }
}
