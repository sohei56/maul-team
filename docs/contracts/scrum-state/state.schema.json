{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Scrum sprint-level state",
  "type": "object",
  "required": ["phase", "created_at", "updated_at"],
  "additionalProperties": true,
  "properties": {
    "phase": {
      "enum": [
        "new",
        "requirements_sprint",
        "backlog_created",
        "sprint_planning",
        "pbi_pipeline_active",
        "review",
        "sprint_review",
        "retrospective",
        "integration_sprint",
        "uat_release",
        "complete"
      ]
    },
    "current_sprint_id": {"type": ["string", "null"], "pattern": "^sprint-[0-9]+$"},
    "product_goal": {"type": ["string", "null"]},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  }
}
